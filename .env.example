# База данных PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=super_secret_password
POSTGRES_DB=redlines_db

# Google OAuth 2.0 (Для авторизации пользователей)
# Как получить: Google Cloud Console -> APIs & Services -> Credentials -> Create Credentials -> OAuth client ID
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google Drive / Storage (Для хранения PDF)
# В будущем здесь будут ключи Service Account для доступа к папке Drive / GCS
GOOGLE_STORAGE_CREDENTIALS_JSON_PATH=./google-creds.json
